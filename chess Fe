  king:{name:'The King',icon:'♚',desc:'The most important piece — the game is over if it falls. The King moves one square in any direction. While slow in the opening and middlegame, the King becomes a powerful attacking piece in the endgame.',moves:'1 square in any direction · Cannot move into check'},
  queen:{name:'The Queen',icon:'♛',desc:'The most powerful piece, combining Rook and Bishop movement. Moving any number of squares in any direction, the Queen dominates open positions. Losing her is almost always decisive.',moves:'Any number of squares in any direction'},
  rook:{name:'The Rook',icon:'♜',desc:'A long-range powerhouse commanding open files and ranks. Rooks are most effective in the endgame and most powerful when doubled. Each player begins with two Rooks.',moves:'Any number of squares horizontally or vertically'},
  bishop:{name:'The Bishop',icon:'♝',desc:"A long-range diagonal attacker confined to squares of one color. Each player has two Bishops — one light-squared, one dark-squared. The Bishop pair is a strategic advantage in open positions.",moves:'Any number of squares diagonally · Confined to one color throughout the game'},
  knight:{name:'The Knight',icon:'♞',desc:"The only piece that can jump over others, moving in an L-shape: two squares in one direction, then one square perpendicular. Knights excel in closed positions where Bishops are restricted.",moves:'L-shape: 2+1 squares · Can jump over pieces · 8 possible destinations'},
  pawn:{name:'The Pawn',icon:'♟',desc:"The soul of chess, in Philidor's words. Pawns move forward but capture diagonally. A pawn reaching the back rank promotes to any piece — almost always a Queen. Pawn structure defines the entire character of a position.",moves:'Forward 1 square (or 2 from start) · Captures diagonally · Promotes on reaching 8th rank'},
};
let activePiece=null;
function togglePiece(key,el){
  const panel=document.getElementById('piecePanel');
  const cards=document.querySelectorAll('.piece-card');
  if(activePiece===key){activePiece=null;panel.classList.remove('open');panel.style.display='none';cards.forEach(c=>c.classList.remove('active'));return}
  activePiece=key;
  cards.forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const d=pieceData[key];
  panel.innerHTML=`<div class="piece-detail-name">${d.icon} <em>${d.name}</em></div><div class="piece-detail-text">${d.desc}</div><div class="piece-detail-moves">↳ ${d.moves}</div>`;
  panel.classList.add('open');panel.style.display='block';
}

/* ── RULES ── */
function toggleRule(el){
  const was=el.classList.contains('expanded');
  document.querySelectorAll('.rule-card').forEach(c=>c.classList.remove('expanded'));
  if(!was) el.classList.add('expanded');
}

/* ── OPENINGS ── */
const openings=[
  {name:'Ruy López (Spanish Game)',eco:'ECO: C60–C99',moves:'1.e4 e5 2.Nf3 Nc6 3.Bb5',detail:'One of the oldest and most classical openings, dating to the 16th century. White pins the knight defending e5, creating enduring pressure. Remains one of the most analyzed openings at grandmaster level.'},
  {name:'Sicilian Defence',eco:'ECO: B20–B99',moves:'1.e4 c5',detail:'The most popular response to 1.e4. Black immediately fights for the center asymmetrically, leading to rich, unbalanced positions. The weapon of choice for players who want to win with Black.'},
  {name:"Queen's Gambit",eco:'ECO: D06–D69',moves:'1.d4 d5 2.c4',detail:"White offers a pawn to gain central control. Despite the name, it isn't a true gambit — White can usually recover the pawn. A cornerstone of classical chess."},
  {name:"King's Indian Defence",eco:'ECO: E60–E99',moves:'1.d4 Nf6 2.c4 g6',detail:"Black allows White to build a strong center, then attacks it. Beloved by dynamic players like Fischer, Kasparov, and Bronstein. Often leads to sharp double-edged battles."},
  {name:'French Defence',eco:'ECO: C00–C19',moves:'1.e4 e6',detail:"A solid if cramped response to 1.e4. Black prepares to challenge the center with …d5. The French leads to strategic pawn-chain battles rather than sharp tactics."},
  {name:'Nimzo-Indian Defence',eco:'ECO: E20–E59',moves:'1.d4 Nf6 2.c4 e6 3.Nc3 Bb4',detail:"Black immediately pins the White knight, preventing e4 and potentially damaging White's structure. Named after hypermodern pioneer Aron Nimzowitsch."},
  {name:'Caro-Kann Defence',eco:'ECO: B10–B19',moves:'1.e4 c6',detail:"A solid answer to 1.e4 — Black prepares …d5 with c6 support, avoiding doubled pawns from the French. Favored by positional players seeking sound endgames."},
  {name:'English Opening',eco:'ECO: A10–A39',moves:'1.c4',detail:"A hypermodern opening controlling the center from the flank. Very flexible and transposes into many other openings. Popularized by Mikhail Botvinnik."},
];
const listEl=document.getElementById('openingsList');
let activeOp=null;
openings.forEach((op,idx)=>{
  const item=document.createElement('div');
  item.className='opening-item';
  item.innerHTML=`<div><div class="opening-name">${op.name}</div><div class="opening-eco">${op.eco}</div></div><div class="opening-moves">${op.moves}</div>`;
  item.addEventListener('click',()=>{
    if(activeOp===idx){activeOp=null;item.classList.remove('active');listEl.querySelectorAll('.opening-detail').forEach(el=>el.remove());return}
    activeOp=idx;
    listEl.querySelectorAll('.opening-item').forEach(el=>el.classList.remove('active'));
    listEl.querySelectorAll('.opening-detail').forEach(el=>el.remove());
    item.classList.add('active');
    const detail=document.createElement('div');
    detail.className='opening-detail open';
    detail.innerHTML=`<div class="opening-detail-text"><strong style="color:var(--ivory);font-style:normal">${op.moves}</strong> — ${op.detail}</div>`;
    item.after(detail);
  });
  listEl.appendChild(item);
});

/* ── QUIZ ── */
const qs=[
  {q:'Which piece is the most powerful in chess?',opts:['King','Queen','Rook','Bishop'],ans:1,ex:"The Queen combines Rook and Bishop movement — worth ~9 points, she dominates open positions."},
  {q:'What happens when a player has no legal moves but is NOT in check?',opts:['Checkmate','Win','Stalemate','Resignation'],ans:2,ex:"Stalemate is a draw — one of chess's most dramatic defensive resources."},
  {q:'En passant is a special move for which piece?',opts:['Knight','Bishop','Queen','Pawn'],ans:3,ex:"Only pawns can perform en passant — a special capture available only on the very next move after a double pawn advance."},
  {q:'How many squares does the King travel when castling?',opts:['1','2','3','4'],ans:1,ex:"The King slides exactly two squares toward the rook, which then jumps to the opposite side."},
  {q:'What ancient Indian game is the ancestor of chess?',opts:['Shatranj','Chaturanga','Go','Shogi'],ans:1,ex:"Chaturanga, ~6th century AD, represented India's four military divisions and is the oldest known ancestor of chess."},
  {q:"What does 'checkmate' derive from?",opts:["French 'échec mat'","Persian 'Shāh Māt'","Arabic 'al-māt'","Sanskrit 'kshatra'"],ans:1,ex:"'Checkmate' comes from the Persian 'Shāh Māt', meaning 'the king is helpless/dead'. Chess traveled from India through Persia to Europe."},
  {q:'In which year was the first official World Chess Championship?',opts:['1851','1872','1886','1900'],ans:2,ex:"1886 — Wilhelm Steinitz defeated Zukertort to become the first undisputed World Champion."},
  {q:'A pawn reaching the back rank must:',opts:['Be removed','Become a King','Promote to any piece except King','Stay as a pawn'],ans:2,ex:"Promotion is mandatory. The pawn must become a Queen, Rook, Bishop, or Knight — almost always a Queen."},
];
let qi=0,score=0,answered=false;
const shuffled=[...qs].sort(()=>Math.random()-.5);

function renderQuiz(){
  const q=shuffled[qi];
  document.getElementById('quizProgress').innerHTML=shuffled.map((_,i)=>`<div class="quiz-dot ${i<qi?'done':''}"></div>`).join('');
  document.getElementById('quizScore').textContent=`Score: ${score} / ${qi}`;
  document.getElementById('quizQ').textContent=q.q;
  document.getElementById('quizFeedback').textContent='';
  document.getElementById('quizNext').style.display='none';
  const opEl=document.getElementById('quizOpts');opEl.innerHTML='';answered=false;
  q.opts.forEach((o,i)=>{
    const btn=document.createElement('button');btn.className='quiz-opt';btn.textContent=o;
    btn.addEventListener('click',()=>{
      if(answered) return;answered=true;
      opEl.querySelectorAll('.quiz-opt').forEach((b,bi)=>{b.disabled=true;if(bi===q.ans)b.classList.add('correct');else if(bi===i)b.classList.add('wrong')});
      if(i===q.ans) score++;
      document.getElementById('quizFeedback').textContent=(i===q.ans?'✓ Correct! ':'✗ ')+q.ex;
      document.getElementById('quizScore').textContent=`Score: ${score} / ${qi+1}`;
      const nb=document.getElementById('quizNext');nb.style.display='inline-block';nb.textContent=qi===shuffled.length-1?'See Results':'Next →';
    });
    opEl.appendChild(btn);
  });
}

function nextQuestion(){
  qi++;
  if(qi>=shuffled.length){
    document.getElementById('quizQ').textContent=`Quiz Complete! You scored ${score} out of ${shuffled.length}.`;
    document.getElementById('quizOpts').innerHTML='';
    document.getElementById('quizFeedback').textContent=score>=6?'Excellent — you truly know your chess!':score>=4?'Good effort — keep studying the game!':'Keep learning — chess rewards patience!';
    const nb=document.getElementById('quizNext');nb.textContent='Restart';nb.style.display='inline-block';
    nb.onclick=()=>{qi=0;score=0;shuffled.sort(()=>Math.random()-.5);nb.onclick=nextQuestion;renderQuiz()};
    document.getElementById('quizProgress').innerHTML=shuffled.map(()=>`<div class="quiz-dot done"></div>`).join('');
    return;
  }
  renderQuiz();
}
renderQuiz();
</script>
